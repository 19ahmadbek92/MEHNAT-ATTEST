# ---------------------------------------------------------------------------
# ISHLAB CHIQARISH (internet): APP_ENV=production, APP_DEBUG=false, APP_URL=https://...
# APP_KEY majburiy: php artisan key:generate --show yoki server muhitida o'rnatiladi.
#
# APP_DEMO_SSO=true — faqat staging/demo: OneID/ERI sinov kirish yo‘llari yoqiladi.
# Productionda false qoldiring (yoki o‘chirib tashlang).
#
# TRUSTED_PROXIES — Nginx/Cloudflare/load balancer orqali HTTPS uchun.
# Bo‘sh = hech qanday proxy ishonchli emas. Docker/LB orqasida: * yoki IP ro‘yxati.
#
# --- Render / Docker (web) ---
# TRUSTED_PROXIES=*  yoki  Render manzillariga mos ro‘yxat (HTTPS redirect uchun).
# LOG_CHANNEL=stderr  konteyner stdout/stderr → platforma "Logs" paneli.
# RUN_MIGRATIONS=true  birinchi deployda migratsiya; keyin false qilib qo‘ying (tez start).
# Health check URL: /container-live.txt (PHP’siz) yoki /up ; chuqur: GET /healthz (DB/cache/disk).
#
# --- Real OneID / E-IMZO (muhim) ---
# APP_DEMO_SSO=false va productionda Real* provider ishlaydi, lekin kod bazasida
# token almashinuvi / ERI to‘liq oqimi hali yakunlanmagan — faqat .env to‘ldirish yetmaydi.
# Hozircha real kirish uchun: (1) stagingda APP_DEMO_SSO=true, yoki (2) Real* providerlarni to‘ldirish.
#
# --- Monitoring / ogohlantirishlar ---
# LOG_LEVEL=warning yoki error (production).
# Ixtiyoriy: LOG_SLACK_WEBHOOK_URL + logging.php da slack kanali; PAPERTRAIL_URL / PAPERTRAIL_PORT.
# Audit: migratsiya 2026_04_17_create_audit_logs — DBda saqlanadi; incidentda secrets-management.md.
# ---------------------------------------------------------------------------
APP_NAME="E-attestatsiya"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_DEMO_SSO=false
# TRUSTED_PROXIES=
# TRUSTED_PROXIES=*
# Demo identlar (staging uchun):
# DEMO_ONEID_NAME=
# DEMO_ONEID_PINFL=
# DEMO_ERI_NAME=
# DEMO_ERI_TIN=
# DEMO_ERI_EMAIL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Production: LOG_CHANNEL=stderr, LOG_LEVEL=warning yoki error
# LOG_SLACK_WEBHOOK_URL=

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
# Production HTTPS: SESSION_ENCRYPT=true tavsiya etiladi
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Docker image (10-laravel.sh): birinchi deploydan keyin RUN_MIGRATIONS=false tavsiya etiladi.
# RUN_MIGRATIONS=true

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Real OneID / E-IMZO integratsiyasi uchun:
ONEID_CLIENT_ID=
ONEID_CLIENT_SECRET=
ONEID_REDIRECT_URI=
ONEID_BASE_URL=

ERI_BASE_URL=
ERI_CLIENT_ID=
ERI_CLIENT_SECRET=

VITE_APP_NAME="${APP_NAME}"
