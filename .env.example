# ---------------------------------------------------------------------------
# ISHLAB CHIQARISH (internet): APP_ENV=production, APP_DEBUG=false, APP_URL=https://...
# APP_KEY majburiy: php artisan key:generate --show yoki server muhitida o'rnatiladi.
#
# APP_DEMO_SSO=true — faqat staging/demo: OneID/ERI sinov kirish yo‘llari yoqiladi.
# Productionda false qoldiring (yoki o‘chirib tashlang).
#
# TRUSTED_PROXIES — Nginx/Cloudflare/load balancer orqali HTTPS uchun.
# Bo‘sh = hech qanday proxy ishonchli emas. Docker/LB orqasida: * yoki IP ro‘yxati.
#
# --- Render / Docker (web) ---
# TRUSTED_PROXIES=*  yoki  Render manzillariga mos ro‘yxat (HTTPS redirect uchun).
# LOG_CHANNEL=stderr  konteyner stdout/stderr → platforma "Logs" paneli.
# RUN_MIGRATIONS=true  birinchi deployda migratsiya; keyin false qilib qo‘ying (tez start).
# Health check URL: /container-live.txt (PHP’siz) yoki /up ; chuqur: GET /healthz (DB/cache/disk).
#
# --- Real OneID / E-IMZO ---
# APP_SSO_ROUTES_ENABLED=true (default) — OneID/ERI marshrutlari ochiq. false bo‘lsa 404.
# OneID: OAuth2 code flow — ONEID_BASE_URL, CLIENT_ID/SECRET, REDIRECT_URI majburiy.
# Qo'shimcha: ONEID_AUTHORIZE_PATH, ONEID_TOKEN_PATH, ONEID_USERINFO_PATH, ONEID_TOKEN_AUTH (basic|body),
# ONEID_SCOPE, ONEID_CLAIM_SUB, ONEID_CLAIM_PINFL, ONEID_CLAIM_NAME, ONEID_CLAIM_EMAIL (nested: masalan user.name).
# ERI: POST /auth/eri — ERI_VERIFICATION_URL (JSON: valid, message) yoki PKCS7 signed_payload (challenge bilan).
# ERI_PKCS7_NOVERIFY=true — sertifikat zanjiri bo‘lmaganda vaqtincha (xavfsizlikni pasaytiradi).
#
# --- Monitoring / ogohlantirishlar ---
# LOG_LEVEL=warning yoki error (production).
# Ixtiyoriy: LOG_SLACK_WEBHOOK_URL + logging.php da slack kanali; PAPERTRAIL_URL / PAPERTRAIL_PORT.
# Audit: migratsiya 2026_04_17_create_audit_logs — DBda saqlanadi; incidentda secrets-management.md.
# ---------------------------------------------------------------------------
APP_NAME="E-attestatsiya"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_DEMO_SSO=false
# APP_SSO_ROUTES_ENABLED=true
# TRUSTED_PROXIES=
# TRUSTED_PROXIES=*
# Demo identlar (staging uchun):
# DEMO_ONEID_NAME=
# DEMO_ONEID_PINFL=
# DEMO_ERI_NAME=
# DEMO_ERI_TIN=
# DEMO_ERI_EMAIL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Production: LOG_CHANNEL=stderr, LOG_LEVEL=warning yoki error
# LOG_SLACK_WEBHOOK_URL=

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
# Production HTTPS: SESSION_ENCRYPT=true tavsiya etiladi
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Docker image (10-laravel.sh): birinchi deploydan keyin RUN_MIGRATIONS=false tavsiya etiladi.
# RUN_MIGRATIONS=true

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Real OneID / E-IMZO integratsiyasi uchun:
ONEID_CLIENT_ID=
ONEID_CLIENT_SECRET=
ONEID_REDIRECT_URI=
ONEID_BASE_URL=
# ONEID_AUTHORIZE_PATH=/oauth2/authorize
# ONEID_TOKEN_PATH=/oauth2/token
# ONEID_USERINFO_PATH=/oauth2/userinfo
# ONEID_TOKEN_AUTH=body
# ONEID_SCOPE="openid profile"
# ONEID_CLAIM_SUB=sub
# ONEID_CLAIM_PINFL=pinfl
# ONEID_CLAIM_NAME=name
# ONEID_CLAIM_EMAIL=email

ERI_BASE_URL=
ERI_CLIENT_ID=
ERI_CLIENT_SECRET=
# ERI_VERIFICATION_URL=https://partner.example/eri/verify
# ERI_VERIFICATION_TIMEOUT=30
# ERI_PKCS7_NOVERIFY=false

VITE_APP_NAME="${APP_NAME}"
